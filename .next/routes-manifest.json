{
  "version": 3,
  "pages404": true,
  "appType": "app",
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "priority": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "onMatchHeaders": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/json/[id]",
      "regex": "^/api/json/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/json/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/dashboard/json/[id]/edit",
      "regex": "^/dashboard/json/([^/]+?)/edit(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/dashboard/json/(?<nxtPid>[^/]+?)/edit(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_global-error",
      "regex": "^/_global\\-error(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_global\\-error(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/apple-icon.png",
      "regex": "^/apple\\-icon\\.png(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/apple\\-icon\\.png(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/json",
      "regex": "^/dashboard/json(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/json(?:/)?$"
    },
    {
      "page": "/dashboard/json/new",
      "regex": "^/dashboard/json/new(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/json/new(?:/)?$"
    },
    {
      "page": "/dashboard/keys",
      "regex": "^/dashboard/keys(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/keys(?:/)?$"
    },
    {
      "page": "/dashboard/logs",
      "regex": "^/dashboard/logs(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/logs(?:/)?$"
    },
    {
      "page": "/dashboard/playground",
      "regex": "^/dashboard/playground(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/playground(?:/)?$"
    },
    {
      "page": "/dashboard/settings",
      "regex": "^/dashboard/settings(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings(?:/)?$"
    },
    {
      "page": "/dashboard/settings/danger",
      "regex": "^/dashboard/settings/danger(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings/danger(?:/)?$"
    },
    {
      "page": "/dashboard/settings/password",
      "regex": "^/dashboard/settings/password(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings/password(?:/)?$"
    },
    {
      "page": "/dashboard/settings/profile",
      "regex": "^/dashboard/settings/profile(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings/profile(?:/)?$"
    },
    {
      "page": "/dashboard/settings/theme",
      "regex": "^/dashboard/settings/theme(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/settings/theme(?:/)?$"
    },
    {
      "page": "/favicon.ico",
      "regex": "^/favicon\\.ico(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/favicon\\.ico(?:/)?$"
    },
    {
      "page": "/icon.png",
      "regex": "^/icon\\.png(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/icon\\.png(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/register",
      "regex": "^/register(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/register(?:/)?$"
    },
    {
      "page": "/verify-email",
      "regex": "^/verify\\-email(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/verify\\-email(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments",
    "clientParamParsing": false,
    "dynamicRSCPrerender": false
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}